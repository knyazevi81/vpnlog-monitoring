{
  "id": null,
  "uid": "xui-dashboard",
  "title": "X-UI VPN Dashboard",
  "tags": ["x-ui", "vpn"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "email",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "query": {
          "type": "labelValues",
          "label": "email",
          "stream": "{job=\"x-ui\"}"
        },
        "label": "Пользователь",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Всего подключений за период",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"x-ui\", email=~\"$email\"} |= \"accepted\" [$__range]))",
          "legendFormat": "Подключения"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "green" },
          "unit": "short"
        }
      }
    },
    {
      "id": 2,
      "title": "Активных пользователей сейчас",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "count(sum by (email) (count_over_time({job=\"x-ui\"} |= \"accepted\" [5m])))",
          "legendFormat": "Активные"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "title": "TCP vs UDP подключения",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"x-ui\", protocol=\"tcp\"} [$__range]))",
          "legendFormat": "TCP"
        },
        {
          "expr": "sum(count_over_time({job=\"x-ui\", protocol=\"udp\"} [$__range]))",
          "legendFormat": "UDP"
        }
      ],
      "options": {
        "pieType": "donut",
        "displayLabels": ["percent", "name"]
      }
    },
    {
      "id": 4,
      "title": "Новых подключений (последний час)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum(count_over_time({job=\"x-ui\"} |= \"accepted\" [1h]))",
          "legendFormat": "За час"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "unit": "short"
        }
      }
    },
    {
      "id": 5,
      "title": "Подключения по времени",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (email) (count_over_time({job=\"x-ui\", email=~\"$email\"} |= \"accepted\" [$__range]))",
          "legendFormat": "{{email}}"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      }
    },
    {
      "id": 6,
      "title": "Топ пользователей по подключениям",
      "type": "bargauge",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (email) (count_over_time({job=\"x-ui\"} |= \"accepted\" [$__range]))",
          "legendFormat": "{{email}}"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient"
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "continuous-GrYlRd" },
          "unit": "short"
        }
      }
    },
    {
      "id": 7,
      "title": "Топ доменов",
      "type": "table",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "sum by (destination) (count_over_time({job=\"x-ui\", email=~\"$email\"} | regexp `(?P<destination>[^:]+):(?P<dest_port>\\d+)$` [$__range]))",
          "legendFormat": "{{destination}}"
        }
      ],
      "options": {
        "sortBy": [{ "displayName": "Value", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 8,
      "title": "Лог событий (live)",
      "type": "logs",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{job=\"x-ui\", email=~\"$email\"} |= \"accepted\"",
          "legendFormat": ""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    }
  ]
}
